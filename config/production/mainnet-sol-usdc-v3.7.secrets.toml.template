# ═══════════════════════════════════════════════════════════════════════════
#  🔒 GRIDZBOTZ SECRETS TEMPLATE — mainnet-sol-usdc-v3.7
#
#  HOW TO USE:
#    cp mainnet-sol-usdc-v3.7.secrets.toml.template \
#       mainnet-sol-usdc-v3.7.secrets.toml
#    # Fill in your real keys below
#    # The *.secrets.toml pattern is in .gitignore — this file stays local
#
#  This template IS committed (safe — contains no real keys).
#  Your filled-in *.secrets.toml is NEVER committed.
#
#  These values override the PLACEHOLDER strings in the main config
#  when your secrets loader / env var injection reads this file.
# ═══════════════════════════════════════════════════════════════════════════

[network]
# Chainstack mainnet endpoint — get key from: https://console.chainstack.com
rpc_url = "https://solana-mainnet.core.chainstack.com/YOUR_CHAINSTACK_KEY"
# Optional WebSocket — uncomment when ws_url is wired in NetworkConfig
# ws_url = "wss://solana-mainnet.core.chainstack.com/YOUR_CHAINSTACK_KEY"

[execution]
# Helius fallback endpoint — get key from: https://dev.helius.xyz/dashboard
rpc_fallback_urls = [
    "https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY",
]
# Jito MEV tip — uncomment when bundle submit is wired in realtrader.rs
# jito_tip_lamports = 10_000

# ─────────────────────────────────────────────────────────────────────────
# Telegram alerts — alternatively export as env vars:
#   export GRIDZBOTZ_TELEGRAM_TOKEN=...
#   export GRIDZBOTZ_TELEGRAM_CHAT_ID=...
# ─────────────────────────────────────────────────────────────────────────
[alerts]
enabled           = true
telegram_bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
telegram_chat_id   = "YOUR_TELEGRAM_CHAT_ID"
