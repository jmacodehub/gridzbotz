# ═══════════════════════════════════════════════════════════════════════════
#  🔐 GRIDZBOTZ — Environment Secrets (Single Source of Truth)
#  V1.2 | fix/env-consolidation
#
#  Setup:
#    1. cp .env.example .env          ← always from project root
#    2. Fill in REQUIRED values
#    3. NEVER commit .env to git (.gitignore already excludes it)
#
#  How it works:
#    TOML configs hold safe defaults/placeholders.
#    src/config/secrets.rs::resolve_secrets() reads GRIDZBOTZ_* vars
#    at startup and overrides the TOML values in memory.
#    All binaries (grid_bot, smoke_test) use the SAME var names.
#
#  Key rotation (zero downtime):
#    1. Generate new key at provider portal
#    2. Update the value below in .env
#    3. Restart bot — no code or TOML changes needed
#
#  See: src/config/secrets.rs for the full resolution logic
# ═══════════════════════════════════════════════════════════════════════════

# ─── REQUIRED: RPC Endpoint ────────────────────────────────────────────────
# Primary Solana RPC — use a private endpoint, NOT the public one.
# Public endpoint (api.mainnet-beta.solana.com) is rate-limited and
# unreliable for trading. Recommended: Chainstack or QuickNode.
# Get yours at: https://chainstack.com  |  https://quicknode.com
GRIDZBOTZ_RPC_URL=https://solana-mainnet.core.chainstack.com/YOUR_KEY_HERE

# ─── OPTIONAL: Fallback RPC ────────────────────────────────────────────────
# Auto-failover if primary RPC is >150ms or fails.
# Recommended: use a different provider than your primary.
# GRIDZBOTZ_FALLBACK_RPC_URL=https://YOUR-HELIUS-ENDPOINT.helius-rpc.com/?api-key=YOUR_KEY

# ─── REQUIRED: Jupiter API Key ─────────────────────────────────────────────
# Used by: grid_bot binary, smoke_test binary, JupiterClient (all routes).
# Get free key at: https://portal.jup.ag
# NOTE: This single var covers ALL binaries. No alias needed.
GRIDZBOTZ_JUPITER_API_KEY=your-jupiter-api-key-here

# ─── REQUIRED: Wallet Path ─────────────────────────────────────────────────
# Absolute path to your Solana keypair JSON file.
# Security check: chmod 600 /path/to/id.json
GRIDZBOTZ_WALLET_PATH=/Users/yourname/.config/solana/id.json

# ─── OPTIONAL: Jito MEV Protection ─────────────────────────────────────────
# Enables Jito bundle submission for MEV protection.
# Recommended when trading above $500 capital.
# 100_000 lamports = ~0.0001 SOL tip per bundle.
# GRIDZBOTZ_JITO_TIP_LAMPORTS=100000

# ─── OPTIONAL: Telegram Alerts ─────────────────────────────────────────────
# Real-time fill + P&L alerts sent to your Telegram.
# Setup guide: docs/TELEGRAM_SETUP.md
#   Step 1: Create bot via @BotFather → get TELEGRAM_BOT_TOKEN
#   Step 2: Get your chat ID via @userinfobot → get TELEGRAM_CHAT_ID
#   Step 3: Uncomment and fill in below, restart bot.
# TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-xxxxxxxxx
# TELEGRAM_CHAT_ID=987654321

# ─── LOGGING ───────────────────────────────────────────────────────────────
# Controls log verbosity for all binaries.
#   info  → normal operation (recommended for production)
#   debug → verbose output (useful for debugging fills/fees)
#   trace → very noisy (use only for deep RPC/Jupiter tracing)
RUST_LOG=info
RUST_ENV=production
