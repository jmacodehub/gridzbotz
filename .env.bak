# ═══════════════════════════════════════════════════════════════════════════
# 🤖 GRIDZBOTZ — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# SETUP:
#   cp .env.example .env
#   # Fill in your values — .env is gitignored, never committed!
#
# USAGE: The bot and smoke_test auto-load this file on startup.
# You no longer need to `export` variables manually.
# ═══════════════════════════════════════════════════════════════════════════

# ── Solana RPC ──────────────────────────────────────────────────────────────
# Free private RPC from chainstack.com, helius.dev, or quicknode.com
# Public endpoint works but will rate-limit in production
RPC_URL=https://solana-mainnet.core.chainstack.com/6ab9c5a91b372ea63ecf3fd08560b281
WSS_URL=wss://solana-mainnet.core.chainstack.com/6ab9c5a91b372ea63ecf3fd08560b281

# ── Jupiter DEX ─────────────────────────────────────────────────────────────
# Get your free key at: https://portal.jup.ag
JUPITER_API_KEY=f628ae97-4308-4acf-82a8-dffca9ee0090

# ── Wallet ──────────────────────────────────────────────────────────────────
# Path to your Solana keypair JSON file (⚠️ NEVER commit the actual file!)
WALLET_PATH=/Users/j-mc/.config/solana/id.json

# ── Grid Strategy Parameters ────────────────────────────────────────────────
# These override values in config/grid_config.toml
# GRID_LEVELS=10
# GRID_SPACING_PCT=0.05        # % between each grid level
# GRID_ORDER_SIZE_SOL=0.05    # SOL per grid order
# GRID_LOWER_PRICE=84.0       # USD - lower bound of grid
# GRID_UPPER_PRICE=97.0      # USD - upper bound of grid

# ── Risk Management ─────────────────────────────────────────────────────────
# MAX_POSITION_SOL=1.0        # Max SOL exposure at any time
# MAX_DAILY_LOSS_USD=50.0     # Emergency stop: max loss per day
STOP_LOSS_PCT=10.0          # % drop from entry before emergency exit
# MAX_DAILY_TRADES=100        # Hard cap on number of swaps per day

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info               # debug | info | warn | error
RUST_BACKTRACE=0            # Set to 1 for full backtraces on panic
