# Rust build artifacts
target/
Cargo.lock

# Logs
logs/
*.log
build.log
last_crash.log

# Archives and backups
archive/
examples/archive/
config/archive/

# Environment files (secrets!)
.env
.env.local
.env.production
.env.bak
*.pem
*.key
keystore*.json

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Test data
errors.txt
error_analysis_*.txt
prices.txt
mainnet-address.txt

# Analysis files
analysis/
typescript/
*.csv

# Development configs (don't commit test configs)
config/testing/
config/test_*.toml
config/*_test.toml

# Environment files (RPC endpoints!)
.env.rpc

# Test results and monitoring
results/
monitoring/
backups/
temp/

# TypeScript experiments
typescript/

# Process IDs
*.pid
grinder.pid

# Specific config folders (keep main config, ignore test variants)
config/devnet/
config/mainnet/
config/paper/
config/production/v5.0_development/
config/production/v6.0_dev/

# ─────────────────────────────────────────────────────────────────────────
# Production secrets — RPC keys, Telegram tokens, Jito tips.
# Template files (*.secrets.toml.template) ARE committed — safe, no real keys.
# Filled-in secrets files (*.secrets.toml) are NEVER committed.
# ─────────────────────────────────────────────────────────────────────────
config/production/*.secrets.toml

# Binary builds
src/bin/

# Shell scripts - ALLOW production scripts, ignore temp/test scripts
# Allow: scripts/ directory (launchers, monitors, etc.)
!scripts/**/*.sh
# But ignore: temp test scripts in root
test_*.sh
quick_*.sh
temp_*.sh

# Runtime output — never commit contents, only folder structure
logs/*
!logs/.gitkeep
fills/*
!fills/.gitkeep
results/*
!results/.gitkeep
metrics/*
!metrics/.gitkeep
analysis/*
!analysis/.gitkeep
!logs/mainnet/.gitkeep
